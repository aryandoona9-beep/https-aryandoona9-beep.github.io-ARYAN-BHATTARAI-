                        </div>
                        <iconify-icon icon="solar:lock-password-linear" class="absolute text-6xl text-emerald-400 drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]"></iconify-icon>
                    </div>
                </div>
            </div>
        </section>

