                                <iconify-icon icon="solar:link-minimalistic-linear" class="text-xl"></iconify-icon>
                            </a>
                        </div>
                        <h3 class="text-xl font-medium text-zinc-100 tracking-tight mb-3 group-hover:text-emerald-400 transition-colors">Secure Login System</h3>
                        <p class="text-sm text-zinc-400 mb-6 line-clamp-3">
                            Built a login system with authentication and password hashing to improve website security and protect user credentials against common database leaks.
                        </p>
                        <div class="flex flex-wrap gap-3 font-mono text-xs text-zinc-500">
                            <span>HTML</span>
                            <span>CSS</span>
                            <span>JavaScript</span>
                            <span>Node.js</span>
                        </div>
